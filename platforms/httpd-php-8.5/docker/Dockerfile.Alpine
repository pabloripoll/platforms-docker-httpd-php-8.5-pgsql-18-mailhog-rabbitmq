## Sources to build the container
FROM alpine:3.24
FROM php:8.5-fpm-alpine

RUN apk add --no-cache bash

ARG UID
ARG GID
ENV UID=${UID}
ENV GID=${GID}
ARG USER
ARG GROUP
ENV USER=${USER}
ENV GROUP=${GROUP}

# Create user and group
RUN addgroup -S --gid ${GID} ${GROUP} \
    && adduser -S --uid ${UID} ${USER} -s /bin/sh -G ${GROUP} ${USER} \
    && apk add --no-cache sudo \
    && chmod u+s /bin/su \
    && echo "${USER} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Install main packages and remove default server definition
RUN apk add --no-cache \
  openrc \
  curl \
  wget \
  openssl \
  apache2 \
  apache2-proxy \
  php-fpm \
  #apache2-ssl \
  zip \
  nano \
  git \
  #ffmpeg \
  libva-dev \
  supervisor

RUN set -xe \
    && apk add --no-cache --virtual .build-deps \
        libzip-dev \
        freetype-dev \
        icu-dev \
        libmcrypt-dev \
        libjpeg-turbo-dev \
        libpng-dev \
        libxslt-dev \
        patch \
        openssh-client

RUN apk add --no-cache \
  php85 \
  php85-cli \
  php85-ctype \
  php85-curl \
  php85-dom \
  php85-fileinfo \
  php85-fpm \
  php85-gd \
  php85-intl \
  php85-mbstring \
  php85-opcache \
  php85-openssl \
  php85-phar \
  php85-session \
  php85-tokenizer \
  php85-soap \
  php85-xml \
  php85-xmlreader \
  php85-xmlwriter \
  php85-simplexml \
  # Databases
  php85-pdo \
  php85-pdo_sqlite \
  php85-sqlite3 \
  # Postgres
  php85-pgsql \
  php85-pdo_pgsql \
  postgresql-dev

# pdo
RUN docker-php-ext-install zip gd bcmath sockets pcntl pdo pdo_pgsql

RUN apk add \
  php85-pecl-amqp
  #php85-pecl-xdebug

# Configure Apache (httpd)
COPY config/httpd/httpd.conf /etc/apache2/httpd.conf
COPY config/httpd/conf.d/ /etc/apache2/conf.d/

# SSL - added only if it is needed
#RUN mv /etc/apache2/conf.d/ssl.conf /etc/apache2/ssl.conf.bak

# Remove default html
RUN rm -rf /var/www/localhost/htdocs

# Configure PHP-FPM
COPY config/php/fpm-pool.conf /etc/php85/php-fpm.d/www.conf
COPY config/php/php.ini /etc/php85/conf.d/custom.ini

# Configure Supervisor
COPY config/supervisor/supervisord.conf /etc/supervisor/supervisord.conf
COPY config/supervisor/conf.d/. /etc/supervisor/conf.d/

COPY --from=composer:latest /usr/bin/composer /usr/local/bin/composer

RUN ln -s -f /usr/bin/php85 /usr/bin/php

COPY config/crontab /var/spool/cron/crontabs/root
RUN chmod -R 644 /var/spool/cron/crontabs/root

RUN mkdir -p /var/www

WORKDIR /var/www

COPY --chown=${USER}:${GROUP} ../ /var/www

RUN rm -rf /var/www/html /var/www/localhost

RUN mkdir -p /var/lib/apache2 /var/log/apache2 \
    && chown -R ${USER}:${GROUP} /var/www /run /var/lib/apache2 /var/log/apache2

USER ${USER}

EXPOSE 80

# Let supervisord start httpd & php-fpm
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]